// Two Threads Studio — Prisma Schema
// Phase 5C: Trust & Risk Management Engine

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Role {
  CUSTOMER
  ADMIN
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
  OUT_OF_STOCK
}

enum ProductType {
  PHYSICAL
  DIGITAL
  WORKSHOP
  SERVICE
}

enum BadgeType {
  NEW
  BEST_SELLER
  LIMITED
  EDITORS_CHOICE
  TRENDING
}

enum DifficultyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum OrderStatus {
  PENDING
  AWAITING_PAYMENT
  CONFIRMED
  PROCESSING
  HANDCRAFTING
  QUALITY_CHECK
  READY_TO_SHIP
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
  CANCELLED
}

enum ShipmentStatus {
  PENDING
  PACKING
  READY
  SHIPPED
  IN_TRANSIT
  DELIVERED
  RETURNED
}

enum PaymentMethod {
  ONLINE
  COD
  BANK_TRANSFER
}

enum AuditAction {
  ORDER_CREATED
  ORDER_UPDATED
  ORDER_CANCELLED
  STATUS_CHANGED
  INVOICE_VIEWED
  PAYMENT_CAPTURED
  PAYMENT_FAILED
  REFUND_INITIATED
  SHIPMENT_CREATED
  // Phase 5C
  RISK_EVALUATED
  TRUST_SCORE_UPDATED
  ORDER_FLAGGED
  ORDER_REVIEWED
  OTP_SENT
  OTP_VERIFIED
  COD_BLOCKED
}

enum AuditActorType {
  CUSTOMER
  ADMIN
  SYSTEM
}

enum CouponType {
  PERCENTAGE
  FIXED
  FREE_SHIPPING
}

// Phase 5C enums

enum RiskDecision {
  APPROVED
  REQUIRES_OTP
  MANUAL_REVIEW
  PREPAID_ONLY
  BLOCKED
}

enum FraudFlagType {
  MULTIPLE_FAILED_PAYMENTS
  MULTIPLE_ACCOUNTS_SAME_PHONE
  MULTIPLE_ACCOUNTS_SAME_ADDRESS
  DISPOSABLE_EMAIL
  TOO_MANY_ORDERS_TODAY
  ADDRESS_MISMATCH
  CHARGEBACK_HISTORY
  REPEATED_CANCELLATIONS
  SUSPICIOUS_PATTERN
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OtpPurpose {
  FIRST_ORDER_VERIFICATION
  COD_VERIFICATION
  HIGH_VALUE_ORDER
  PHONE_CHANGE
  PHONE_REGISTRATION
}

enum ReturnEligibility {
  FULL_RETURN
  EXCHANGE_ONLY
  NO_RETURN
}

// ─────────────────────────────────────────────
// Authentication Models (Phase 2)
// ─────────────────────────────────────────────

model User {
  id                   String    @id @default(cuid())
  firstName            String
  lastName             String
  email                String    @unique
  passwordHash         String
  /// Primary commerce identity — required for order fulfillment
  phone                String?
  /// True after OTP or manual verification by admin
  phoneVerified        Boolean   @default(false)
  avatarUrl            String?
  role                 Role      @default(CUSTOMER)
  isVerified           Boolean   @default(false)
  isActive             Boolean   @default(true)
  lastLogin            DateTime?

  dateOfBirth          DateTime?
  gender               String?
  profileImage         String?
  preferredLanguage    String    @default("en")
  marketingConsent     Boolean   @default(false)
  newsletterSubscribed Boolean   @default(false)
  memberSince          DateTime  @default(now())

  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  refreshTokens  RefreshToken[]
  reviews        Review[]
  wishlist       Wishlist[]
  addresses      Address[]
  cart           Cart?
  orders         Order[]
  customerRisk   CustomerRisk?
  otpVerifications OtpVerification[]

  @@map("users")
}

model RefreshToken {
  id         String    @id @default(cuid())
  tokenHash  String    @unique
  userId     String
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?
  deviceInfo String?
  ipAddress  String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────
// Catalog Models (Phase 3)
// ─────────────────────────────────────────────

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  image       String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  @@index([isActive])
  @@index([sortOrder])
  @@map("categories")
}

model Collection {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  bannerImage String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  @@index([isActive])
  @@map("collections")
}

model Tag {
  id   String @id @default(cuid())
  name String
  slug String @unique

  products ProductTag[]

  @@map("tags")
}

model Product {
  id               String          @id @default(cuid())
  name             String
  slug             String          @unique
  shortDescription String?
  description      String
  sku              String?         @unique
  categoryId       String
  collectionId     String?

  price        Decimal  @db.Decimal(10, 2)
  comparePrice Decimal? @db.Decimal(10, 2)
  costPrice    Decimal? @db.Decimal(10, 2)

  stockQuantity     Int     @default(0)
  lowStockThreshold Int     @default(5)
  trackInventory    Boolean @default(true)

  status     ProductStatus   @default(DRAFT)
  type       ProductType     @default(PHYSICAL)
  badge      BadgeType?
  difficulty DifficultyLevel?
  featured   Boolean         @default(false)

  isHandmade              Boolean @default(true)
  isSustainable           Boolean @default(false)
  isCustomizable          Boolean @default(false)
  isPersonalizable        Boolean @default(false)
  madeToOrder             Boolean @default(false)
  estimatedProductionDays Int?
  estimatedShippingDays   Int?
  estimatedTime           String?

  materials         String[]
  materialsIncluded String[]
  technique         String?
  careInstructions  String?
  origin            String?

  weight     Float?
  dimensions Json?

  seoTitle       String?
  seoDescription String?

  /// Phase 5C: false for personalized/custom products — enforced by CodEligibilityEngine
  allowCod  Boolean @default(true)

  salesCount Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category   Category    @relation(fields: [categoryId], references: [id])
  collection Collection? @relation(fields: [collectionId], references: [id])
  images     ProductImage[]
  variants   ProductVariant[]
  tags       ProductTag[]
  reviews    Review[]
  wishlist   Wishlist[]
  cartItems  CartItem[]
  returnPolicy ReturnPolicy?

  @@index([status])
  @@index([featured])
  @@index([categoryId])
  @@index([collectionId])
  @@index([price])
  @@index([createdAt(sort: Desc)])
  @@index([badge])
  @@index([status, featured])
  @@index([status, categoryId])
  @@index([salesCount(sort: Desc)])
  @@map("products")
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  altText   String?
  sortOrder Int     @default(0)
  isPrimary Boolean @default(false)
  width     Int?
  height    Int?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([productId, sortOrder])
  @@map("product_images")
}

model ProductVariant {
  id              String  @id @default(cuid())
  productId       String
  name            String
  value           String
  sku             String? @unique
  priceAdjustment Decimal @default(0) @db.Decimal(10, 2)
  stockQuantity   Int     @default(0)
  isActive        Boolean @default(true)

  product   Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems CartItem[]

  @@index([productId])
  @@map("product_variants")
}

model ProductTag {
  productId String
  tagId     String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
  @@map("product_tags")
}

model Review {
  id         String   @id @default(cuid())
  rating     Int
  title      String?
  comment    String
  productId  String
  userId     String
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId])
  @@index([productId])
  @@index([userId])
  @@index([rating])
  @@map("reviews")
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@map("wishlists")
}

enum AddressType {
  HOME
  WORK
  OTHER
}

model Address {
  id                String      @id @default(cuid())
  userId            String
  fullName          String
  phone             String
  company           String?
  line1             String
  line2             String?
  city              String
  district          String?
  state             String
  country           String
  postalCode        String
  landmark          String?
  type              AddressType @default(HOME)
  isDefaultBilling  Boolean     @default(false)
  isDefaultShipping Boolean     @default(false)
  deletedAt         DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  shippingOrders Order[] @relation("ShippingAddress")
  billingOrders  Order[] @relation("BillingAddress")

  @@index([userId])
  @@map("addresses")
}

model Cart {
  id        String   @id @default(cuid())
  userId    String?  @unique
  guestId   String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@map("carts")
}

model CartItem {
  id            String   @id @default(cuid())
  cartId        String
  productId     String
  variantId     String?
  quantity      Int
  unitPrice     Decimal  @db.Decimal(10, 2)
  productName   String
  primaryImage  String
  sku           String?
  variantName   String?
  customization Json?
  giftWrap      Boolean  @default(false)
  engravingText String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  cart    Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@unique([cartId, productId, variantId])
  @@index([cartId])
  @@index([productId])
  @@map("cart_items")
}

// ─────────────────────────────────────────────
// Order Models (Phase 5A — extended in 5B/5C)
// ─────────────────────────────────────────────

model Order {
  id          String @id @default(cuid())
  orderNumber String @unique

  userId            String
  shippingAddressId String
  billingAddressId  String

  subtotal   Decimal @db.Decimal(10, 2)
  discount   Decimal @default(0) @db.Decimal(10, 2)
  shipping   Decimal @default(0) @db.Decimal(10, 2)
  tax        Decimal @default(0) @db.Decimal(10, 2)
  grandTotal Decimal @db.Decimal(10, 2)
  currency   String  @default("INR")

  orderStatus   OrderStatus   @default(PENDING)
  paymentStatus PaymentStatus @default(PENDING)
  paymentMethod PaymentMethod @default(ONLINE)

  notes          String?
  couponCode     String?
  couponDiscount Decimal    @default(0) @db.Decimal(10, 2)
  promotionId    String?
  couponType     CouponType?

  estimatedCompletionDate DateTime?

  // Phase 5B: payment reference
  paymentReference String?
  paidAt           DateTime?

  // Phase 5C: risk & trust
  riskDecision     RiskDecision?
  riskScore        Int?
  requiresReview   Boolean       @default(false)
  otpVerified      Boolean       @default(false)
  /// Prepaid discount applied as percentage (from PREPAID_DISCOUNT_PERCENT env)
  prepaidDiscountPct Decimal?    @db.Decimal(5, 2)
  prepaidDiscount    Decimal     @default(0) @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user            User    @relation(fields: [userId], references: [id])
  shippingAddress Address @relation("ShippingAddress", fields: [shippingAddressId], references: [id])
  billingAddress  Address @relation("BillingAddress", fields: [billingAddressId], references: [id])

  items         OrderItem[]
  statusHistory OrderStatusHistory[]
  auditLogs     OrderAuditLog[]
  payment       Payment?
  shipment      Shipment?
  reviewQueue   ManualReviewQueue?
  fraudFlags    FraudFlag[]

  @@index([userId])
  @@index([orderStatus])
  @@index([paymentStatus])
  @@index([riskDecision])
  @@index([requiresReview])
  @@index([createdAt(sort: Desc)])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String?
  variantId String?

  productName  String
  productSlug  String
  productImage String
  sku          String?
  variantName  String?

  unitPrice Decimal @db.Decimal(10, 2)
  quantity  Int
  lineTotal Decimal @db.Decimal(10, 2)

  customization Json?
  engravingText String?
  giftWrap      Boolean @default(false)

  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_items")
}

model OrderStatusHistory {
  id             String       @id @default(cuid())
  orderId        String
  previousStatus OrderStatus?
  newStatus      OrderStatus
  changedBy      String
  note           String?
  createdAt      DateTime     @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_status_history")
}

model OrderAuditLog {
  id        String         @id @default(cuid())
  orderId   String
  action    AuditAction
  actorType AuditActorType
  actorId   String
  details   Json?
  createdAt DateTime       @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_audit_logs")
}

model IdempotencyKey {
  id             String   @id @default(cuid())
  userId         String
  key            String   @unique
  requestHash    String
  responseStatus Int
  responseBody   Json
  createdAt      DateTime @default(now())
  expiresAt      DateTime

  @@map("idempotency_keys")
}

// ─────────────────────────────────────────────
// Payment Models (Phase 5B)
// ─────────────────────────────────────────────

model Payment {
  id                String        @id @default(cuid())
  orderId           String        @unique
  provider          String        @default("RAZORPAY")

  providerOrderId   String?
  providerPaymentId String?       @unique
  providerSignature String?

  amount         Decimal @db.Decimal(10, 2)
  currency       String  @default("INR")

  status         PaymentStatus @default(PENDING)
  method         String?
  transactionFee Decimal?      @db.Decimal(10, 2)

  failureReason String?
  failureCode   String?

  paidAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  metadata Json?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
  @@index([providerOrderId])
  @@map("payments")
}

// ─────────────────────────────────────────────
// Shipment Models (Phase 5B)
// ─────────────────────────────────────────────

model Shipment {
  id             String         @id @default(cuid())
  orderId        String         @unique
  provider       String         @default("MOCK")

  trackingNumber String?
  carrier        String?
  shippingMethod String?        @default("STANDARD")

  status            ShipmentStatus @default(PENDING)

  labelUrl          String?
  estimatedDelivery DateTime?
  shippedAt         DateTime?
  deliveredAt       DateTime?

  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
  @@map("shipments")
}

// ─────────────────────────────────────────────
// Risk & Trust Models (Phase 5C)
// ─────────────────────────────────────────────

/// One record per customer. Upserted on every order event.
/// Trust score is CALCULATED from counters — never set manually (except admin override).
model CustomerRisk {
  id     String @id @default(cuid())
  userId String @unique

  // Order outcome counters (source of trust score)
  ordersPlaced      Int @default(0)
  ordersDelivered   Int @default(0)
  rtoCount          Int @default(0)
  cancelledOrders   Int @default(0)
  prepaidOrders     Int @default(0)
  codOrders         Int @default(0)
  chargebackCount   Int @default(0)
  failedPayments    Int @default(0)

  /// Computed from counters by TrustScoreEngine (0–100). Default 50 for new users.
  trustScore Int @default(50)

  // Restrictions
  isBlocked     Boolean  @default(false)
  blockReason   String?
  /// If set, orders above this value require MANUAL_REVIEW
  maxOrderValue Decimal? @db.Decimal(10, 2)

  // Timestamps
  lastRiskEvaluation DateTime?
  lastOrderAt        DateTime?
  /// Admin notes visible only in admin dashboard
  adminNotes         String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([trustScore])
  @@index([isBlocked])
  @@map("customer_risk")
}

/// OTP record — hashed OTP stored, max 3 attempts, 10-minute TTL
model OtpVerification {
  id        String     @id @default(cuid())
  userId    String
  /// Phone or email the OTP was sent to
  recipient String
  purpose   OtpPurpose
  /// bcrypt-hashed OTP
  otpHash   String
  expiresAt DateTime
  verified  Boolean    @default(false)
  attempts  Int        @default(0)
  createdAt DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([recipient, purpose])
  @@map("otp_verifications")
}

/// Fraud signals detected by FraudDetector engine
model FraudFlag {
  id      String        @id @default(cuid())
  userId  String?
  orderId String?
  type    FraudFlagType
  details Json?
  resolved  Boolean  @default(false)
  resolvedBy String?
  resolvedAt DateTime?
  createdAt DateTime @default(now())

  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([orderId])
  @@index([type])
  @@index([resolved])
  @@map("fraud_flags")
}

/// Orders that need admin review before fulfillment begins
model ManualReviewQueue {
  id         String       @id @default(cuid())
  orderId    String       @unique
  /// Comma-separated human-readable reasons
  reason     String
  riskScore  Int
  status     ReviewStatus @default(PENDING)
  reviewedBy String?
  reviewedAt DateTime?
  reviewNote String?
  createdAt  DateTime     @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("manual_review_queue")
}

/// Per-product return/refund rules enforced by backend
model ReturnPolicy {
  id          String            @id @default(cuid())
  productId   String            @unique
  eligibility ReturnEligibility
  windowDays  Int               @default(0)
  /// Displayed to customer if they attempt a return
  reason      String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("return_policies")
}

// ─────────────────────────────────────────────
// Studio Settings (Phase 6A)
// ─────────────────────────────────────────────

/// Single-row configuration table for all business settings.
/// Use StudioSettings.upsert({ where: { singleton: true } }) pattern.
model StudioSettings {
  id        String   @id @default(cuid())
  /// Enforced singleton: always true — ensures only one row exists
  singleton Boolean  @unique @default(true)

  // ── Company Details ───────────────────────
  companyName      String  @default("Two Threads Studio")
  companyTagline   String?
  companyEmail     String  @default("hello@twothreads.in")
  companyPhone     String?
  companyAddress   String?
  companyCity      String?
  companyState     String?
  companyCountry   String  @default("India")
  companyPincode   String?
  companyWebsite   String?

  // ── GST & Tax ─────────────────────────────
  gstNumber        String?
  gstEnabled       Boolean @default(true)
  gstPercent       Decimal @default(0) @db.Decimal(5, 2)
  /// "inclusive" = price includes GST | "exclusive" = GST added on top
  gstMode          String  @default("inclusive")
  hsnCode          String?

  // ── Invoice Settings ──────────────────────
  invoicePrefix    String  @default("INV")
  invoiceFooter    String?
  invoiceLogo      String?

  // ── Shipping Configuration ────────────────
  freeShippingThreshold  Decimal  @default(500) @db.Decimal(10, 2)
  standardShippingCharge Decimal  @default(60)  @db.Decimal(10, 2)
  expressShippingCharge  Decimal  @default(150) @db.Decimal(10, 2)
  shippingEnabled        Boolean  @default(true)
  shippingNote           String?

  // ── COD Rules ─────────────────────────────
  codEnabled             Boolean  @default(true)
  codMaxOrderValue       Decimal  @default(5000) @db.Decimal(10, 2)
  codExtraCharge         Decimal  @default(0)    @db.Decimal(10, 2)
  prepaidDiscountPercent Decimal  @default(5)    @db.Decimal(5, 2)

  // ── Return Policy (Global Default) ───────
  returnWindowDays       Int      @default(7)
  exchangeWindowDays     Int      @default(14)
  returnPolicy           String?

  // ── Business Contact ──────────────────────
  supportEmail           String?
  supportPhone           String?
  supportHours           String?

  // ── Email Templates ───────────────────────
  orderConfirmationNote  String?
  shippingUpdateNote     String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("studio_settings")
}
