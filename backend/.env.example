PORT=5000
NODE_ENV=development

# Database Configuration (Supabase PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Supabase API
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_ANON_KEY="your_supabase_anon_key"
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key"

# Authentication Secrets
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your_64_byte_random_hex_secret"
JWT_REFRESH_SECRET="your_64_byte_random_hex_secret_different_from_above"

# Email
RESEND_API_KEY="your_resend_api_key"
EMAIL_FROM="Two Threads Studio <onboarding@resend.dev>"
ADMIN_NOTIFICATION_EMAILS="sethysaiyangyadatta@gmail.com,shreyasisahoo116@gmail.com"
HIGH_VALUE_ORDER_THRESHOLD_INR=5000

# Admin Dashboard
ADMIN_FRONTEND_URL="https://admin.twothreadsstudio.com"

# Razorpay
RAZORPAY_KEY_ID="your_razorpay_key_id"
RAZORPAY_KEY_SECRET="your_razorpay_key_secret"
RAZORPAY_WEBHOOK_SECRET="your_razorpay_webhook_secret"

# Shipping Provider (mock | shiprocket | delhivery)
SHIPPING_PROVIDER="mock"

# CORS
FRONTEND_URL="http://localhost:3000"

# Logging Configuration
LOG_LEVEL=debug
LOG_HTTP_BODY=false
LOG_HEADERS=false
LOG_PRETTY=true

